<?xml version="1.0" encoding="UTF-8" ?>
<!-- ***********************************************************************
     Nombre: Colors.xaml
     Colores de la aplicación - Conversión fiel de VB6
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     Colores de los formularios VB6
     *********************************************************************** -->
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    
    <!-- Colores principales de la aplicación VB6 -->
    <!-- VB6: BackColor = &H00B06000& (BGR) = RGB(0, 96, 176) -->
    <Color x:Key="ColorFondoPrincipal">#00B060</Color>
    
    <!-- VB6: FrameLectura BackColor = &H00808080& (Gris) -->
    <Color x:Key="ColorFondoFrame">#808080</Color>
    
    <!-- VB6: fraArticulo BackColor = &H00C0C0C0& (Gris claro) -->
    <Color x:Key="ColorFondoArticulo">#C0C0C0</Color>
    
    <!-- VB6: ColorRojo = &H8080FF (BGR) = RGB(255, 128, 128) -->
    <Color x:Key="ColorRojo">#FF8080</Color>
    
    <!-- VB6: ColorVerde = &H80FF80 (BGR) = RGB(128, 255, 128) -->
    <Color x:Key="ColorVerde">#80FF80</Color>
    
    <!-- VB6: txtLecturaCodigo focus = &HC0FFC0 -->
    <Color x:Key="ColorFocoEntrada">#C0FFC0</Color>
    
    <!-- VB6: vbWhite -->
    <Color x:Key="ColorBlanco">#FFFFFF</Color>
    
    <!-- VB6: Texto blanco en encabezados -->
    <Color x:Key="ColorTextoEncabezado">#FFFFFF</Color>
    
    <!-- Colores primarios MAUI -->
    <Color x:Key="Primary">#0060B0</Color>
    <Color x:Key="Secondary">#808080</Color>
    <Color x:Key="Tertiary">#C0C0C0</Color>
    
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="Yellow100Accent">#F7B548</Color>
    <Color x:Key="Yellow200Accent">#FFD590</Color>
    <Color x:Key="Yellow300Accent">#FFE5B9</Color>
    <Color x:Key="Cyan100Accent">#28C2D1</Color>
    <Color x:Key="Cyan200Accent">#7BDDEF</Color>
    <Color x:Key="Cyan300Accent">#C3F2F4</Color>

</ResourceDictionary>
