<?xml version="1.0" encoding="UTF-8" ?>
<!-- ***********************************************************************
     Nombre: Styles.xaml
     Estilos de la aplicación - Conversión fiel de VB6
     OPTIMIZADO para pistola Zebra de 4" (480x640 aprox)
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     Estilos de los formularios VB6
     *********************************************************************** -->
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Estilo para títulos (equivalente a lbTexto en VB6) -->
    <!-- VB6: Font MS Sans Serif 12pt Bold, ForeColor White, BackColor Gray -->
    <!-- OPTIMIZADO: Reducido de 18 a 14 para pantalla 4" -->
    <Style x:Key="TituloStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="TextColor" Value="{StaticResource ColorTextoEncabezado}"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ColorFondoFrame}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="Padding" Value="2"/>
    </Style>

    <!-- Estilo para etiquetas normales -->
    <!-- OPTIMIZADO: Reducido de 14 a 11 para pantalla 4" -->
    <Style x:Key="EtiquetaStyle" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

    <!-- Estilo para valores (Labels con fondo blanco como en VB6) -->
    <!-- VB6: BackColor = &H00FFFFFF&, Alignment = Center -->
    <!-- OPTIMIZADO: Reducido de 14 a 11, padding de 5 a 2 para pantalla 4" -->
    <Style x:Key="ValorStyle" TargetType="Label">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ColorBlanco}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="MinimumHeightRequest" Value="22"/>
    </Style>

    <!-- Estilo para valores grandes (como lbBAC con Font Bold) -->
    <!-- OPTIMIZADO: Reducido de 16 a 12, padding de 5 a 2 para pantalla 4" -->
    <Style x:Key="ValorGrandeStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ColorBlanco}"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="MinimumHeightRequest" Value="24"/>
    </Style>

    <!-- Estilo para entrada de texto (txtLecturaCodigo) -->
    <!-- VB6: Font Arial 14.25pt, Appearance Flat, MaxLength 36 -->
    <!-- OPTIMIZADO: Reducido de 20 a 16, altura fija para pantalla 4" -->
    <Style x:Key="EntradaCodigoStyle" TargetType="Entry">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ColorBlanco}"/>
        <Setter Property="MaxLength" Value="36"/>
        <Setter Property="Keyboard" Value="Default"/>
        <Setter Property="HeightRequest" Value="38"/>
    </Style>

    <!-- Estilo para botones de acción -->
    <!-- VB6: CommandButton -->
    <!-- OPTIMIZADO: Reducido altura de 50 a 36, margin de 5 a 2 para pantalla 4" -->
    <Style x:Key="BotonAccionStyle" TargetType="Button">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Estilo para botón Salir -->
    <!-- OPTIMIZADO: Reducido altura de 50 a 36, margin de 5 a 2 para pantalla 4" -->
    <Style x:Key="BotonSalirStyle" TargetType="Button">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="HeightRequest" Value="36"/>
        <Setter Property="BackgroundColor" Value="#C0C0C0"/>
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Estilo para Frame contenedor (FrameLectura, fraArticulo) -->
    <!-- OPTIMIZADO: Reducido padding de 10 a 4 para pantalla 4" -->
    <Style x:Key="FrameContenedorStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorFondoFrame}"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HasShadow" Value="False"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <!-- Estilo para Frame de datos (fraArticulo) -->
    <!-- OPTIMIZADO: Reducido padding de 10 a 4 para pantalla 4" -->
    <Style x:Key="FrameDatosStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource ColorFondoArticulo}"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HasShadow" Value="False"/>
        <Setter Property="Margin" Value="0"/>
    </Style>

    <!-- Estilo para CheckBox (opciones) -->
    <!-- OPTIMIZADO: Escala reducida para pantalla 4" -->
    <Style x:Key="OpcionCheckStyle" TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Primary}"/>
        <Setter Property="Scale" Value="0.85"/>
    </Style>

    <!-- Estilo para Picker (ComboBox) -->
    <!-- OPTIMIZADO: Reducido de 14 a 11 para pantalla 4" -->
    <Style x:Key="ComboStyle" TargetType="Picker">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="BackgroundColor" Value="{StaticResource ColorBlanco}"/>
        <Setter Property="HeightRequest" Value="32"/>
    </Style>

    <!-- Estilo para CollectionView (equivalente a UltraGrid) -->
    <Style x:Key="ListaArticulosStyle" TargetType="CollectionView">
        <Setter Property="BackgroundColor" Value="#FFDCCE"/>
    </Style>

    <!-- Estilo implícito para ActivityIndicator -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}"/>
    </Style>

    <!-- Estilo implícito para Button -->
    <!-- OPTIMIZADO: Reducido tamaño para pantalla 4" -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Estilo implícito para Entry -->
    <!-- OPTIMIZADO: Reducido de 14 a 12 para pantalla 4" -->
    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="BackgroundColor" Value="White"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- Estilo implícito para Label -->
    <!-- OPTIMIZADO: Reducido de 14 a 11 para pantalla 4" -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="Black"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- Estilo para CheckBox en opciones compactas -->
    <Style x:Key="CheckBoxCompactoStyle" TargetType="CheckBox">
        <Setter Property="Scale" Value="0.8"/>
        <Setter Property="Color" Value="{StaticResource Primary}"/>
    </Style>

    <!-- Estilo para etiquetas de checkbox compactas -->
    <Style x:Key="EtiquetaCheckStyle" TargetType="Label">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="VerticalTextAlignment" Value="Center"/>
    </Style>

</ResourceDictionary>
