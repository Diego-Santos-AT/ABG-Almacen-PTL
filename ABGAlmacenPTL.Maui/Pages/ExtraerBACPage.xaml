<?xml version="1.0" encoding="utf-8" ?>
<!-- ***********************************************************************
     Nombre: ExtraerBACPage.xaml
     Formulario para la extracción de un BAC de una ubicación de PTL
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     frmExtraerBAC.frm de VB6 - línea por línea
     
     Realización:   A.Esteban (VB6) - 05/06/20
     *********************************************************************** -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ABGAlmacenPTL.Maui.Pages.ExtraerBACPage"
             Title="EXTRAER BAC"
             BackgroundColor="{StaticResource ColorFondoFrame}">

    <ScrollView>
        <VerticalStackLayout Spacing="10" Padding="10">

            <!-- FrameLectura -->
            <Frame Style="{StaticResource FrameContenedorStyle}">
                <VerticalStackLayout Spacing="10">
                    
                    <!-- lbTexto - Título -->
                    <Label Text="EXTRAER BAC" 
                           Style="{StaticResource TituloStyle}"/>

                    <!-- Fila: txtLecturaCodigo + cmdAccion(990) SALIR -->
                    <Grid ColumnDefinitions="3*,*">
                        <Entry x:Name="txtLecturaCodigo" 
                               Style="{StaticResource EntradaCodigoStyle}"
                               Placeholder="Leer BAC"
                               MaxLength="36"
                               Completed="TxtLecturaCodigo_Completed"
                               Focused="TxtLecturaCodigo_Focused"
                               Unfocused="TxtLecturaCodigo_Unfocused"/>
                        
                        <Button x:Name="cmdSalir" 
                                Text="SALIR"
                                Style="{StaticResource BotonSalirStyle}"
                                Grid.Column="1"
                                Clicked="CmdSalir_Clicked"/>
                    </Grid>

                    <!-- Label8 - Instrucción -->
                    <Label Text="Leer BAC de PTL"
                           HorizontalTextAlignment="Center"
                           BackgroundColor="{StaticResource ColorBlanco}"/>

                </VerticalStackLayout>
            </Frame>

            <!-- Picture1 - Opciones de estado -->
            <Frame BackgroundColor="{StaticResource ColorFondoArticulo}" Padding="10">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="2*,*">
                    
                    <!-- oEstado(0) - Cerrar BAC -->
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0">
                        <RadioButton x:Name="oEstadoCerrar"
                                     Content="Cerrar BAC"
                                     GroupName="EstadoBAC"
                                     CheckedChanged="OEstado_CheckedChanged"/>
                    </HorizontalStackLayout>

                    <!-- oEstado(1) - Abrir BAC (Default True) -->
                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0">
                        <RadioButton x:Name="oEstadoAbrir"
                                     Content="Abrir BAC"
                                     GroupName="EstadoBAC"
                                     IsChecked="True"
                                     CheckedChanged="OEstado_CheckedChanged"/>
                    </HorizontalStackLayout>

                    <!-- cmdAccion(0) - CANCELAR -->
                    <Button x:Name="cmdCancelar"
                            Text="CANCELAR"
                            Grid.Row="0" Grid.Column="1"
                            Grid.RowSpan="2"
                            VerticalOptions="Center"
                            Clicked="CmdCancelar_Clicked"/>
                </Grid>
            </Frame>

            <!-- fraArticulo - Datos del BAC -->
            <Frame Style="{StaticResource FrameDatosStyle}">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                      ColumnDefinitions="Auto,*,Auto,*">

                    <!-- Ubicación -->
                    <Label Text="Ubicación" Grid.Row="0" Grid.Column="0"/>
                    <Label x:Name="lbUbicacion" 
                           Style="{StaticResource ValorGrandeStyle}"
                           Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"/>

                    <!-- BAC + Estado -->
                    <Label Text="BAC" Grid.Row="1" Grid.Column="0"/>
                    <Label x:Name="lbBAC" 
                           Style="{StaticResource ValorGrandeStyle}"
                           Grid.Row="1" Grid.Column="1"/>
                    <Label x:Name="lbEstadoBAC" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"/>

                    <!-- Grupo + Tablilla + Uds -->
                    <Label Text="Grupo" Grid.Row="2" Grid.Column="0"/>
                    <Label x:Name="lbGrupo" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="2" Grid.Column="1"/>
                    <Label Text="Tablilla" Grid.Row="2" Grid.Column="2"/>
                    <Label x:Name="lbTablilla" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="2" Grid.Column="3"/>

                    <!-- Uds -->
                    <Label Text="Uds" Grid.Row="3" Grid.Column="2"/>
                    <Label x:Name="lbUds" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="3" Grid.Column="3"/>

                    <!-- Peso + Volumen -->
                    <Label Text="Peso" Grid.Row="4" Grid.Column="0"/>
                    <Label x:Name="lbPeso" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="4" Grid.Column="1"/>
                    <Label Text="Volumen" Grid.Row="4" Grid.Column="2"/>
                    <Label x:Name="lbVolumen" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="4" Grid.Column="3"/>

                    <!-- Tipo Caja + Nombre -->
                    <Label Text="Tipo Caja" Grid.Row="5" Grid.Column="0"/>
                    <Label x:Name="lbTipoCaja" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="5" Grid.Column="1"/>
                    <Label x:Name="lbNombreCaja" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2"/>

                </Grid>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
