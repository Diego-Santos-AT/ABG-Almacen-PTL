<?xml version="1.0" encoding="utf-8" ?>
<!-- ***********************************************************************
     Nombre: MenuPage.xaml
     Menú Principal - Conversión fiel de VB6
     OPTIMIZADO para pistola Zebra de 4" (480x640 aprox)
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     frmMenu.frm de VB6
     *********************************************************************** -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ABGAlmacenPTL.Maui.Pages.MenuPage"
             Title="Menú Principal"
             BackgroundColor="{StaticResource ColorFondoPrincipal}">

    <Grid Padding="8">
        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
            
            <!-- Título -->
            <Label Text="MENÚ PRINCIPAL" 
                   Style="{StaticResource TituloStyle}"
                   FontSize="16"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10"/>

            <!-- Botones de menú (altura optimizada para 4") -->
            <Button Text="Consultas PTL" 
                    Style="{StaticResource BotonAccionStyle}"
                    HeightRequest="40"
                    FontSize="12"
                    Clicked="OnConsultasPTLClicked"/>

            <Button Text="Extraer BAC" 
                    Style="{StaticResource BotonAccionStyle}"
                    HeightRequest="40"
                    FontSize="12"
                    Clicked="OnExtraerBACClicked"/>

            <Button Text="Ubicar BAC" 
                    Style="{StaticResource BotonAccionStyle}"
                    HeightRequest="40"
                    FontSize="12"
                    Clicked="OnUbicarBACClicked"/>

            <Button Text="Repartir Artículo" 
                    Style="{StaticResource BotonAccionStyle}"
                    HeightRequest="40"
                    FontSize="12"
                    Clicked="OnRepartirArticuloClicked"/>

            <Button Text="Empaquetar BAC" 
                    Style="{StaticResource BotonAccionStyle}"
                    HeightRequest="40"
                    FontSize="12"
                    Clicked="OnEmpaquetarBACClicked"/>

            <BoxView HeightRequest="10" Color="Transparent"/>

            <Button Text="SALIR" 
                    Style="{StaticResource BotonSalirStyle}"
                    HeightRequest="40"
                    FontSize="12"
                    Clicked="OnSalirClicked"/>

        </VerticalStackLayout>
    </Grid>

</ContentPage>
