<?xml version="1.0" encoding="utf-8" ?>
<!-- ***********************************************************************
     Nombre: EmpaquetarBACPage.xaml
     Formulario para el empaquetado de BACs en CAJAs de PTL
     OPTIMIZADO para pistola Zebra de 4" (480x640 aprox)
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     frmEmpaquetarBAC.frm de VB6 - línea por línea
     
     Realización:   A.Esteban (VB6) - 02/09/20
     *********************************************************************** -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ABGAlmacenPTL.Maui.Pages.EmpaquetarBACPage"
             Title="EMPAQUETAR BAC"
             BackgroundColor="{StaticResource ColorFondoFrame}">

    <!-- OPTIMIZADO: Sin ScrollView para mejor rendimiento en pantalla 4" -->
    <VerticalStackLayout Spacing="2" Padding="4">

        <!-- FrameLectura -->
        <Frame Style="{StaticResource FrameContenedorStyle}">
            <VerticalStackLayout Spacing="2">
                
                <!-- lbTexto - Título -->
                <Label x:Name="lbTexto" 
                       Text="EMPAQUETAR BAC" 
                       Style="{StaticResource TituloStyle}"/>

                <!-- Fila: txtLecturaCodigo + cmdSalir -->
                <Grid ColumnDefinitions="3*,*" ColumnSpacing="4">
                    <Entry x:Name="txtLecturaCodigo" 
                           Style="{StaticResource EntradaCodigoStyle}"
                           Placeholder="Leer BAC"
                           MaxLength="36"
                           Completed="TxtLecturaCodigo_Completed"
                           Focused="TxtLecturaCodigo_Focused"
                           Unfocused="TxtLecturaCodigo_Unfocused"/>
                    
                    <Button x:Name="cmdSalir" 
                            Text="SALIR"
                            Style="{StaticResource BotonSalirStyle}"
                            Grid.Column="1"
                            Clicked="CmdSalir_Clicked"/>
                </Grid>

                <!-- Label8 - Instrucción -->
                <Label x:Name="Label8" 
                       Text="Leer BAC para Empaquetar"
                       FontSize="9"
                       HorizontalTextAlignment="Center"
                       BackgroundColor="{StaticResource ColorBlanco}"/>

            </VerticalStackLayout>
        </Frame>

        <!-- fraOpciones - Opciones de empaquetado (Compacto 2 filas) -->
        <Frame x:Name="fraOpciones" Style="{StaticResource FrameDatosStyle}">
            <Grid RowDefinitions="22,22" ColumnDefinitions="*,*,*" RowSpacing="2" ColumnSpacing="2">
                
                <!-- Fila 1: Cerrar, Extraer, Crear -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="0">
                    <CheckBox x:Name="chkCerrarBAC" IsChecked="True" Scale="0.7"/>
                    <Label Text="Cerrar" FontSize="9" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="0">
                    <CheckBox x:Name="chkExtraerBAC" IsChecked="True" Scale="0.7"/>
                    <Label Text="Extraer" FontSize="9" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="0" Grid.Column="2" Spacing="0">
                    <CheckBox x:Name="chkCrearCAJA" IsChecked="True" Scale="0.7"/>
                    <Label Text="Crear" FontSize="9" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>
                
                <!-- Fila 2: Imprimir, RelCont, Empaq -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="0">
                    <CheckBox x:Name="chkImprimirCAJA" IsChecked="True" Scale="0.7"/>
                    <Label Text="Imprimir" FontSize="9" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="0">
                    <CheckBox x:Name="chkRelContenido" IsChecked="False" Scale="0.7"/>
                    <Label Text="Rel.Cont" FontSize="9" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>
                <HorizontalStackLayout Grid.Row="1" Grid.Column="2" Spacing="0">
                    <CheckBox x:Name="chkEmpaquetado" IsChecked="False" Scale="0.7"/>
                    <Label Text="Empaq" FontSize="9" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>

            </Grid>
        </Frame>

        <!-- fraAcciones - Botones de acción (3x3 grid compacto) -->
        <Frame x:Name="fraAcciones" Style="{StaticResource FrameDatosStyle}" IsVisible="False">
            <VerticalStackLayout Spacing="2">
                
                <Label x:Name="lbAcciones" 
                       Text="ACCIONES" 
                       FontSize="10"
                       FontAttributes="Bold" 
                       BackgroundColor="{StaticResource ColorFondoFrame}"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="1"/>

                <!-- Botones de acción en grid 3x3 -->
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="30,30,30" RowSpacing="2" ColumnSpacing="2">
                    <Button x:Name="cmdCerrarBAC" Text="Cerrar" 
                            Grid.Row="0" Grid.Column="0"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdCerrarBAC_Clicked"/>
                    <Button x:Name="cmdExtraerBAC" Text="Extraer" 
                            Grid.Row="0" Grid.Column="1"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdExtraerBAC_Clicked"/>
                    <Button x:Name="cmdCrearCAJA" Text="Crear" 
                            Grid.Row="0" Grid.Column="2"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdCrearCAJA_Clicked"/>
                    
                    <Button x:Name="cmdImprimirCAJA" Text="Imprimir" 
                            Grid.Row="1" Grid.Column="0"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdImprimirCAJA_Clicked"/>
                    <Button x:Name="cmdRelContenido" Text="Rel.Cont" 
                            Grid.Row="1" Grid.Column="1"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdRelContenido_Clicked"/>
                    <Button x:Name="cmdEmpaquetado" Text="Empaq" 
                            Grid.Row="1" Grid.Column="2"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdEmpaquetado_Clicked"/>
                    
                    <Button x:Name="cmdCambiarCAJA" Text="TipoCaja" 
                            Grid.Row="2" Grid.Column="0"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdCambiarCAJA_Clicked"/>
                    <Button x:Name="cmdCambiarUDS" Text="CambUds" 
                            Grid.Row="2" Grid.Column="1"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdCambiarUDS_Clicked"/>
                    <Button x:Name="cmdCombinarCAJAS" Text="Combinar" 
                            Grid.Row="2" Grid.Column="2"
                            FontSize="9" HeightRequest="30" Padding="2"
                            Clicked="CmdCombinarCAJAS_Clicked"/>
                </Grid>

                <!-- Botón Volver -->
                <Button x:Name="cmdVolver" Text="VOLVER" 
                        Style="{StaticResource BotonSalirStyle}"
                        HeightRequest="32"
                        Clicked="CmdVolver_Clicked"/>

            </VerticalStackLayout>
        </Frame>

        <!-- fraBAC - Datos del BAC -->
        <Frame x:Name="fraBAC" Style="{StaticResource FrameDatosStyle}">
            <VerticalStackLayout Spacing="2">
                
                <Label Text="DATOS BAC" 
                       FontSize="10"
                       FontAttributes="Bold" 
                       BackgroundColor="{StaticResource ColorFondoFrame}"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="1"/>
                
                <Grid RowDefinitions="20,20,20,20"
                      ColumnDefinitions="45,*,45,*"
                      RowSpacing="1" ColumnSpacing="2">

                    <!-- BAC + Estado -->
                    <Label Text="BAC" Grid.Row="0" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbBAC" 
                           Style="{StaticResource ValorGrandeStyle}"
                           FontSize="10"
                           Grid.Row="0" Grid.Column="1"/>
                    <Label x:Name="lbEstadoBAC" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2"/>

                    <!-- Grupo + Tablilla -->
                    <Label Text="Grupo" Grid.Row="1" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbGrupo" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="1" Grid.Column="1"/>
                    <Label Text="Tabl." Grid.Row="1" Grid.Column="2" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbTablilla" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="1" Grid.Column="3"/>

                    <!-- Peso + Volumen -->
                    <Label Text="Peso" Grid.Row="2" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbPeso" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="2" Grid.Column="1"/>
                    <Label Text="Vol." Grid.Row="2" Grid.Column="2" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbVolumen" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="2" Grid.Column="3"/>

                    <!-- Tipo Caja -->
                    <Label Text="TCaja" Grid.Row="3" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbTipoCaja" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"/>

                </Grid>

            </VerticalStackLayout>
        </Frame>

        <!-- fraCAJA - Datos de la CAJA -->
        <Frame x:Name="fraCAJA" Style="{StaticResource FrameDatosStyle}" IsVisible="False">
            <VerticalStackLayout Spacing="2">
                
                <Label Text="DATOS CAJA" 
                       FontSize="10"
                       FontAttributes="Bold" 
                       BackgroundColor="{StaticResource ColorFondoFrame}"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="1"/>
                
                <Grid RowDefinitions="20,20,20"
                      ColumnDefinitions="45,*,45,*"
                      RowSpacing="1" ColumnSpacing="2">

                    <!-- SSCC -->
                    <Label Text="SSCC" Grid.Row="0" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbSSCC" 
                           Style="{StaticResource ValorGrandeStyle}"
                           FontSize="9"
                           Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"/>

                    <!-- Peso + Volumen -->
                    <Label Text="Peso" Grid.Row="1" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbPesoCAJA" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="1" Grid.Column="1"/>
                    <Label Text="Vol." Grid.Row="1" Grid.Column="2" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbVolumenCAJA" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="1" Grid.Column="3"/>

                    <!-- Tipo -->
                    <Label Text="Tipo" Grid.Row="2" Grid.Column="0" FontSize="9" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbTipoCAJA" 
                           Style="{StaticResource ValorStyle}"
                           FontSize="9"
                           Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"/>

                </Grid>

            </VerticalStackLayout>
        </Frame>

        <!-- Lista de contenido (altura reducida) -->
        <Frame x:Name="fraLista" Style="{StaticResource FrameDatosStyle}" IsVisible="False">
            <VerticalStackLayout Spacing="2">
                
                <Label x:Name="lbTituloLista" 
                       Text="CONTENIDO BAC" 
                       FontSize="10"
                       FontAttributes="Bold" 
                       BackgroundColor="{StaticResource ColorFondoFrame}"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="1"/>
                
                <CollectionView x:Name="lstContenido" 
                                SelectionMode="Single"
                                HeightRequest="80"
                                SelectionChanged="LstContenido_SelectionChanged">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="2" ColumnDefinitions="50,*,35" HeightRequest="20">
                                <Label Text="{Binding Articulo}" Grid.Column="0" FontSize="9"/>
                                <Label Text="{Binding Nombre}" Grid.Column="1" FontSize="9" LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Cantidad}" Grid.Column="2" FontSize="9" HorizontalTextAlignment="End"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </Frame>

        <!-- Tipos de caja (selector compacto) -->
        <Frame x:Name="fraTiposCaja" Style="{StaticResource FrameDatosStyle}" IsVisible="False">
            <VerticalStackLayout Spacing="2">
                
                <Label Text="TIPOS DE CAJA" 
                       FontSize="10"
                       FontAttributes="Bold" 
                       BackgroundColor="{StaticResource ColorFondoFrame}"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Padding="1"/>
                
                <Picker x:Name="cmbTiposCaja" 
                        Style="{StaticResource ComboStyle}"
                        HeightRequest="30"
                        SelectedIndexChanged="CmbTiposCaja_SelectedIndexChanged"/>
                
                <Button x:Name="cmdAplicarTipoCaja" Text="APLICAR TIPO" 
                        Style="{StaticResource BotonAccionStyle}"
                        HeightRequest="32"
                        Clicked="CmdAplicarTipoCaja_Clicked"/>

            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>

</ContentPage>
