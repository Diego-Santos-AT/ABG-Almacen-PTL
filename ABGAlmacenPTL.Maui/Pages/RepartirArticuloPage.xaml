<?xml version="1.0" encoding="utf-8" ?>
<!-- ***********************************************************************
     Nombre: RepartirArticuloPage.xaml
     Formulario para el reparto de Artículos en BACs casilleros de PTL
     OPTIMIZADO para pistola Zebra de 4" (480x640 aprox)
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     frmRepartirArticulo.frm de VB6 - línea por línea
     
     Realización:   A.Esteban (VB6) - 02/09/20
     *********************************************************************** -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ABGAlmacenPTL.Maui.Pages.RepartirArticuloPage"
             Title="REPARTIR ARTICULO"
             BackgroundColor="{StaticResource ColorFondoFrame}">

    <!-- OPTIMIZADO: Sin ScrollView para mejor rendimiento en pantalla 4" -->
    <VerticalStackLayout Spacing="4" Padding="4">

        <!-- FrameLectura -->
        <Frame Style="{StaticResource FrameContenedorStyle}">
            <VerticalStackLayout Spacing="4">
                
                <!-- lbTexto - Título -->
                <Label Text="REPARTIR ARTICULO" 
                       Style="{StaticResource TituloStyle}"/>

                <!-- Label8 - Instrucción -->
                <Label Text="Leer o teclear Artículo"
                       FontSize="10"
                       HorizontalTextAlignment="Center"
                       TextColor="White"/>

                <!-- txtLecturaCodigo - Entrada de código -->
                <Entry x:Name="txtLecturaCodigo" 
                       Style="{StaticResource EntradaCodigoStyle}"
                       Placeholder="Código artículo"
                       MaxLength="36"
                       Completed="TxtLecturaCodigo_Completed"
                       Focused="TxtLecturaCodigo_Focused"
                       Unfocused="TxtLecturaCodigo_Unfocused"/>

                <!-- Label4 + Combo1 + pColor -->
                <Grid ColumnDefinitions="40,*,35" ColumnSpacing="4">
                    <Label Text="Puesto" 
                           FontSize="10"
                           VerticalOptions="Center"/>
                    
                    <Picker x:Name="Combo1" 
                            Style="{StaticResource ComboStyle}"
                            Grid.Column="1"
                            SelectedIndexChanged="Combo1_SelectedIndexChanged"/>
                    
                    <!-- pColor - Indicador de color -->
                    <BoxView x:Name="pColor" 
                             Color="#808080"
                             Grid.Column="2"
                             HeightRequest="26"
                             WidthRequest="35"
                             VerticalOptions="Center"/>
                </Grid>

                <!-- Datos del artículo - Grid compacto -->
                <Grid RowDefinitions="22,35,22,22,22"
                      ColumnDefinitions="55,*,55,*"
                      RowSpacing="2" ColumnSpacing="2">

                    <!-- Código -->
                    <Label Text="Código" Grid.Row="0" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbArticulo" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"/>

                    <!-- Nombre -->
                    <Label x:Name="lbNombreArticulo" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                           LineBreakMode="TailTruncation"
                           FontSize="10"/>

                    <!-- EAN13 -->
                    <Label Text="EAN13" Grid.Row="2" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbEAN13" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"/>

                    <!-- STD -->
                    <Label Text="STD" Grid.Row="3" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbSTD" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="3" Grid.Column="1"/>

                    <!-- Peso + Volumen -->
                    <Label Text="Peso" Grid.Row="4" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbPeso" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="4" Grid.Column="1"/>
                    <Label Text="Vol." Grid.Row="4" Grid.Column="2" FontSize="10" VerticalTextAlignment="Center"/>
                    <Label x:Name="lbVolumen" 
                           Style="{StaticResource ValorStyle}"
                           Grid.Row="4" Grid.Column="3"/>

                </Grid>

                <!-- cmdAccion(990) - SALIR -->
                <Button x:Name="cmdSalir" 
                        Text="SALIR"
                        Style="{StaticResource BotonSalirStyle}"
                        Clicked="CmdSalir_Clicked"/>

            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>

</ContentPage>
