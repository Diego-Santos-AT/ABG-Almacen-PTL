<?xml version="1.0" encoding="utf-8" ?>
<!-- ***********************************************************************
     Nombre: UbicarBACPage.xaml
     Formulario para la ubicación de un BAC en una ubicación de PTL
     OPTIMIZADO para pistola Zebra de 4" (480x640 aprox)
     
     Creación:      Conversión de VB6 a .NET MAUI
     Basado en:     frmUbicarBAC.frm de VB6 - línea por línea
     
     Realización:   A.Esteban (VB6) - 05/06/20
     *********************************************************************** -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ABGAlmacenPTL.Maui.Pages.UbicarBACPage"
             Title="UBICAR BAC"
             BackgroundColor="{StaticResource ColorFondoFrame}">

    <!-- OPTIMIZADO: Sin ScrollView para mejor rendimiento en pantalla 4" -->
    <VerticalStackLayout Spacing="4" Padding="4">

        <!-- FrameLectura -->
        <Frame Style="{StaticResource FrameContenedorStyle}">
            <VerticalStackLayout Spacing="4">
                
                <!-- lbTexto - Título -->
                <Label Text="UBICAR BAC" 
                       Style="{StaticResource TituloStyle}"/>

                <!-- Fila: txtLecturaCodigo + cmdAccion(990) SALIR -->
                <Grid ColumnDefinitions="3*,*" ColumnSpacing="4">
                    <Entry x:Name="txtLecturaCodigo" 
                           Style="{StaticResource EntradaCodigoStyle}"
                           Placeholder="Leer código"
                           MaxLength="36"
                           Completed="TxtLecturaCodigo_Completed"
                           Focused="TxtLecturaCodigo_Focused"
                           Unfocused="TxtLecturaCodigo_Unfocused"/>
                    
                    <Button x:Name="cmdSalir" 
                            Text="SALIR"
                            Style="{StaticResource BotonSalirStyle}"
                            Grid.Column="1"
                            Clicked="CmdSalir_Clicked"/>
                </Grid>

                <!-- Label8 - Instrucción -->
                <Label Text="Leer BAC o Ubicación PTL"
                       FontSize="10"
                       HorizontalTextAlignment="Center"
                       BackgroundColor="{StaticResource ColorBlanco}"/>

            </VerticalStackLayout>
        </Frame>

        <!-- Picture1 - Opciones de estado -->
        <Frame BackgroundColor="{StaticResource ColorFondoArticulo}" Padding="4">
            <Grid RowDefinitions="28,28" ColumnDefinitions="2*,*" RowSpacing="2" ColumnSpacing="4">
                
                <!-- oEstado(0) - Cerrar BAC -->
                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                    <RadioButton x:Name="oEstadoCerrar"
                                 Content=""
                                 GroupName="EstadoBAC"
                                 Scale="0.85"
                                 CheckedChanged="OEstado_CheckedChanged"/>
                    <Label Text="Cerrar BAC" FontSize="11" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>

                <!-- oEstado(1) - Abrir BAC (Default True) -->
                <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="2">
                    <RadioButton x:Name="oEstadoAbrir"
                                 Content=""
                                 GroupName="EstadoBAC"
                                 IsChecked="True"
                                 Scale="0.85"
                                 CheckedChanged="OEstado_CheckedChanged"/>
                    <Label Text="Abrir BAC" FontSize="11" VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>

                <!-- cmdAccion(0) - CANCELAR -->
                <Button x:Name="cmdCancelar"
                        Text="CANCELAR"
                        Grid.Row="0" Grid.Column="1"
                        Grid.RowSpan="2"
                        Style="{StaticResource BotonSalirStyle}"
                        VerticalOptions="Center"
                        Clicked="CmdCancelar_Clicked"/>
            </Grid>
        </Frame>

        <!-- fraArticulo - Datos del BAC -->
        <Frame Style="{StaticResource FrameDatosStyle}">
            <Grid RowDefinitions="22,22,22,22,22,22"
                  ColumnDefinitions="55,*,55,*"
                  RowSpacing="2" ColumnSpacing="2">

                <!-- Ubicación -->
                <Label Text="Ubic." Grid.Row="0" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbUbicacion" 
                       Style="{StaticResource ValorGrandeStyle}"
                       Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"/>

                <!-- BAC + Estado -->
                <Label Text="BAC" Grid.Row="1" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbBAC" 
                       Style="{StaticResource ValorGrandeStyle}"
                       Grid.Row="1" Grid.Column="1"/>
                <Label x:Name="lbEstadoBAC" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2"/>

                <!-- Grupo + Tablilla -->
                <Label Text="Grupo" Grid.Row="2" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbGrupo" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="2" Grid.Column="1"/>
                <Label Text="Tablilla" Grid.Row="2" Grid.Column="2" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbTablilla" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="2" Grid.Column="3"/>

                <!-- Uds -->
                <Label Text="Uds" Grid.Row="3" Grid.Column="2" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbUds" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="3" Grid.Column="3"/>

                <!-- Peso + Volumen -->
                <Label Text="Peso" Grid.Row="4" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbPeso" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="4" Grid.Column="1"/>
                <Label Text="Vol." Grid.Row="4" Grid.Column="2" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbVolumen" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="4" Grid.Column="3"/>

                <!-- Tipo Caja + Nombre -->
                <Label Text="T.Caja" Grid.Row="5" Grid.Column="0" FontSize="10" VerticalTextAlignment="Center"/>
                <Label x:Name="lbTipoCaja" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="5" Grid.Column="1"/>
                <Label x:Name="lbNombreCaja" 
                       Style="{StaticResource ValorStyle}"
                       Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2"/>

            </Grid>
        </Frame>

    </VerticalStackLayout>

</ContentPage>
